# --- 🏗️ GODOT CORE ---
# This is the big one. It holds all auto-generated textures/metadata.
# Godot recreates this folder every time you open the project.
.godot/
# Godot 3.x leftover (just in case)
.import/

# --- 🧪 TEMP & TRANSLATIONS ---
*.tmp
*.translation

# --- 🛠️ EXPORT & SECRETS ---
# Prevents local export settings and potentially sensitive paths/keys from leaking.
export.cfg
export_presets.cfg
export_credentials.cfg

# --- 💻 OS JUNK ---
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~

# --- 📦 BUILDS ---
# Keeps your finished games (.exe, .apk) off GitHub. 
# Use GitHub "Releases" for these instead!
build/
bin/
*.exe
*.pck
*.apk

# --- ☕ MONO / C# (If you ever switch) ---
.mono/
data_*/
mono_crash.*.json