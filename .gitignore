# --- Godot 4 Core Ignores ---
# This folder contains all imported assets and metadata. 
# It is auto-generated by Godot and should NEVER be on GitHub.
.godot/

# --- System & Editor Junk ---
# Ignore local editor settings that shouldn't be shared with others
.tmp/
*.tmp
export_presets.cfg
editor_settings-4.trep

# --- Export Artifacts ---
# Don't upload your finished builds (the .exe or .apk files)
# You should keep these local or use GitHub "Releases" for them.
build/
bin/
*.exe
*.pck
*.zip
*.apk
*.ipa
*.app

# --- OS Specific Junk ---
.DS_Store
Thumbs.db

# --- Mobile (If you ever use it) ---
/android/
/ios/

# --- Extra Safety ---
# If you ever create a "secret" file for keys inside the project,
# you can name it something like "secret_keys.txt" and add it here.
# keys.txt
# .env